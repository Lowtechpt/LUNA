@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-display: "Space Grotesk", sans-serif;
  --font-logo: "Orbitron", sans-serif;
  --color-brand: #e11d48;
}

@layer base {
  body {
    @apply bg-black text-white antialiased font-sans;
  }
}

.glass-card {
  @apply bg-white/5 backdrop-blur-lg border border-white/10;
}

.text-gradient {
  @apply bg-clip-text text-transparent bg-gradient-to-r from-white via-white/80 to-white/40;
}

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap');
